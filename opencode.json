{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "build",

  "instructions": [
    "C:/Users/lenov/.config/opencode/AGENTS.md",
    "AGENTS.md",
    ".opencode/PROJECT.md"
  ],

  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "rm -rf *": "deny",
      "rm -r *": "deny",
      "rm -f *": "deny",
      "del /s *": "deny",
      "del /q *": "deny",
      "del /f *": "deny",
      "Remove-Item -Recurse *": "deny",
      "Remove-Item -Force *": "deny",
      "format *": "deny",
      "shutdown *": "deny",
      "reg delete *": "deny",
      "sudo *": "deny",
      "git push --force *": "deny",
      "git push -f *": "deny",
      "git filter-branch *": "deny",
      "git push --force-with-lease *": "ask",
      "git reset --hard *": "ask",
      "git clean -fd *": "ask",
      "git clean -fx *": "ask",
      "npm publish *": "ask",
      "pnpm publish *": "ask",
      "yarn publish *": "ask",
      "vercel --prod *": "ask",
      "vercel deploy --prod *": "ask",
      "DROP *": "deny",
      "TRUNCATE *": "deny",
      "*": "allow"
    },
    "skill": {
      "*": "deny",
      "nueva-calculadora": "allow",
      "auditoria-ymyl": "allow",
      "seo-adsense": "allow",
      "web-factory": "deny",
      "pyme-template-intelligence": "deny"
    }
  },

  "watcher": {
    "ignore": [
      "node_modules/**",
      ".next/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".vercel/**",
      "coverage/**",
      "**/*.tsbuildinfo",
      "tsconfig.tsbuildinfo"
    ]
  },

  "agent": {
